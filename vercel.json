{
  "version": 2,
  "buildCommand": "pnpm build",
  "functions": {
    "server/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/public/index.html"
    }
  ]
}
